# =============================================================================
# Intent Detection — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Install python-dotenv to auto-load:
#   pip install python-dotenv
# =============================================================================

# --- LLM Judge API Keys (only one needed) ---

# Gemini (recommended — free tier at https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Groq (free tier at https://console.groq.com)
GROQ_API_KEY=

# OpenAI (paid — https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# --- LLM Judge Defaults ---

# Provider: gemini | groq | openai
LLM_JUDGE_PROVIDER=gemini

# Model override (leave empty for provider default)
LLM_JUDGE_MODEL=

# --- Monitoring Thresholds ---

MONITOR_OOD_THRESHOLD=0.05
MONITOR_WRONG_THRESHOLD=0.15
MONITOR_SAMPLE_RATE=0.1

# --- Model Training ---

BASE_MODEL=roberta-base
LORA_R=8
LORA_ALPHA=16
LORA_DROPOUT=0.1
LEARNING_RATE=2e-4
EPOCHS=5
BATCH_SIZE=16
